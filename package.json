{
  "name": "agent-treasury",
  "version": "1.0.0",
  "private": true,
  "description": "AgentTreasury CORE — Autonomous DAO CFO (Tether Hackathon Galactica: WDK Edition)",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build:backend": "npm --prefix backend run build",
    "build:frontend": "npm --prefix frontend run build",
    "typecheck": "npm --prefix backend run typecheck && npm --prefix frontend run build",
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vvv",
    "contracts:deploy": "cd contracts && forge script script/Deploy.s.sol --rpc-url $RPC_URL --broadcast --verify",
    "demo:video": "node scripts/record-demo.mjs",
    "demo:voiceover": "node scripts/add-voiceover.mjs"
  },
  "keywords": [
    "tether",
    "hackathon",
    "wdk",
    "openclaw",
    "dao",
    "treasury",
    "agents"
  ],
  "license": "MIT",
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "playwright": "^1.58.2",
    "say": "^0.16.0"
  }
}

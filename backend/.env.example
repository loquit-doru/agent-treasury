# AgentTreasury Backend Configuration

# OpenAI-compatible API Key (required — works with OpenAI, Groq, etc.)
OPENAI_API_KEY=sk-your-api-key-or-gsk_groq-key

# LLM Model (default: gpt-4 for OpenAI, llama-3.3-70b-versatile for Groq)
LLM_MODEL=llama-3.3-70b-versatile

# LLM Base URL (optional — set for Groq or other OpenAI-compatible providers)
# Groq: https://api.groq.com/openai/v1
# OpenAI: leave empty (default)
LLM_BASE_URL=https://api.groq.com/openai/v1

# Fallback LLM (optional — auto-switches on 429 / rate limit)
# Example: use OpenAI as fallback when Groq hits rate limits
# LLM_FALLBACK_API_KEY=sk-your-openai-key
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_NAME=openai

# WDK Seed Phrase (required - 12 words)
WDK_SEED_PHRASE=your twelve word seed phrase here do not reuse

# Blockchain Configuration (Arbitrum One)
RPC_URL=https://arbitrum-one-rpc.publicnode.com
CHAIN_ID=42161

# Contract Addresses (Arbitrum One — deployed with security fixes 2026-03-11)
USDT_ADDRESS=0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9
TREASURY_VAULT_ADDRESS=0x5503e9d53592B7D896E135804637C1710bDD5A64
CREDIT_LINE_ADDRESS=0x236AB6D30F70D7aB6c272aCB3b186D925Bcae1a0

# DeFi Protocol Addresses (Arbitrum One)
AAVE_POOL_ADDRESS=0x794a61358D6845594F94dc1DB02A252b5b4814aD

# Server Configuration
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# API Secret — set this to a random secret to protect mutation endpoints (POST/DELETE)
# Leave empty to skip auth (dev/hackathon mode). Required in production.
# API_SECRET=your-random-secret-here

# Telegram Bot (NOT IMPLEMENTED — placeholder for future integration)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# AgentTreasury Backend Configuration

# OpenAI-compatible API Key (required — works with OpenAI, Groq, etc.)
OPENAI_API_KEY=sk-your-api-key-or-gsk_groq-key

# LLM Model (default: gpt-4 for OpenAI, llama-3.3-70b-versatile for Groq)
LLM_MODEL=llama-3.3-70b-versatile

# LLM Base URL (optional — set for Groq or other OpenAI-compatible providers)
# Groq: https://api.groq.com/openai/v1
# OpenAI: leave empty (default)
LLM_BASE_URL=https://api.groq.com/openai/v1

# Fallback LLM (optional — auto-switches on 429 / rate limit)
# Example: use OpenAI as fallback when Groq hits rate limits
# LLM_FALLBACK_API_KEY=sk-your-openai-key
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_FALLBACK_BASE_URL=
# LLM_FALLBACK_NAME=openai

# WDK Seed Phrase (required - 12 words, Sepolia testnet only!)
WDK_SEED_PHRASE=your twelve word seed phrase here for testnet only do not reuse

# Blockchain Configuration
RPC_URL=https://rpc.sepolia.org
CHAIN_ID=11155111

# Contract Addresses (update after deployment)
USDT_ADDRESS=0xaA8E23Fb1079EA71e0a56F48a2aA51851D8433D0
TREASURY_VAULT_ADDRESS=
CREDIT_LINE_ADDRESS=

# DeFi Protocol Addresses (Sepolia)
AAVE_POOL_ADDRESS=0x6Ae43d3271ff6888e7Fc43Fd7321a503104E31D7

# Server Configuration
PORT=3001
LOG_LEVEL=info

# Telegram Bot (optional — create via @BotFather, get chat ID via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
